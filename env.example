# Potat API Bearer Token
# Required
BEARER_TOKEN=

# Potat API execute endpoint url
# Optional, defaults to https://api.potat.app/execute
# API_URL=https://api.potat.app/execute

# PotatBotat Bot Prefix
# Optional, defaults to #
# BOT_PREFIX=#

# Web port that hosts web dasboard and API
# Optional, defaults to 3000
# WEB_PORT=3000

# Web Dashboard Enabled Boolean
# Optional, defaults to true
# WEB_DASHBOARD_ENABLED=true
